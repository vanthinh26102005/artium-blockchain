{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "nest start api-gateway --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:artwork": "nest start artwork-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:community": "nest start community-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:crm": "nest start crm-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:events": "nest start events-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:identity": "nest start identity-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:messaging": "nest start messaging-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:notifications": "nest start notifications-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:orders": "nest start orders-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:payments": "nest start payments-service --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:all": "concurrently --kill-others-on-fail --names \"ADMIN,ARTWORK,COMMUNITY,CONTENT,CRM,EVENTS,IDENTITY,INVENTORY,INVOICING,MEDIA,MESSAGING,NOTIFY,ORDERS,PAYMENTS,SEARCH,SELLER\" -c \"bgBlue.bold,bgGreen.bold,bgYellow.bold,bgMagenta.bold,bgCyan.bold,bgRed.bold,bgWhite.black.bold,bgGray.bold,bgBlueBright.bold,bgGreenBright.bold,bgYellowBright.bold,bgMagentaBright.bold,bgCyanBright.bold,bgRedBright.bold,bgBlack.white.bold,bgWhite.bold.blue\" \"npm:dev:admin-reporting\" \"npm:dev:artwork\" \"npm:dev:community\" \"npm:dev:content\" \"npm:dev:crm\" \"npm:dev:events\" \"npm:dev:identity\" \"npm:dev:inventory-sales\" \"npm:dev:invoicing\" \"npm:dev:media\" \"npm:dev:messaging\" \"npm:dev:notifications\" \"npm:dev:orders\" \"npm:dev:payments\" \"npm:dev:search-recommendation\" \"npm:dev:seller-profile\"",
    "seed": "tsx --tsconfig ./tsconfig.json seed-all.ts",
    "seed:identity": "tsx --tsconfig ./tsconfig.build.json apps/identity-service/src/db/seeds/run-seeds.ts",
    "seed:artwork": "tsx --tsconfig ./tsconfig.json apps/artwork-service/src/db/seeds/run-seeds.ts",
    "seed:messaging": "tsx --tsconfig ./tsconfig.json apps/messaging-service/src/db/seeds/run-seeds.ts",
    "build:workspace": "yarn run build --workspaces",
    "build:gateway": "nest build api-gateway",
    "build:artwork": "nest build artwork-service",
    "build:identity": "nest build identity-service",
    "build:community": "nest build community-service",
    "build:crm": "nest build crm-service",
    "build:events": "nest build events-service",
    "build:invoicing": "nest build invoicing-service",
    "build:media": "nest build media-service",
    "build:messaging": "nest build messaging-service",
    "build:notifications": "nest build notifications-service",
    "build:orders": "nest build orders-service",
    "build:seller-profile": "nest build seller-profile-service",
    "docker:up:isolated": "docker compose -f docker-compose.yml -f docker-compose.isolated.yml --profile isolated up -d",
    "docker:up:shared": "docker compose -f docker-compose.yml -f docker-compose.shared.yml --profile shared up -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.isolated.yml -f docker-compose.shared.yml down",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/backend/test/jest-e2e.json"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@apollo/subgraph": "^2.11.2",
    "@as-integrations/express5": "^1.1.2",
    "@golevelup/nestjs-rabbitmq": "^6.0.2",
    "@google-cloud/storage": "^7.18.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.1.11",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.8",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.4",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.8",
    "@stripe/react-stripe-js": "^5.6.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cache-manager": "^7.2.3",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.5.1",
    "firebase-admin": "^13.5.0",
    "fs": "^0.0.1-security",
    "google-auth-library": "^10.4.0",
    "graphql": "^16.11.0",
    "graphql-tools": "^9.0.20",
    "i": "^0.3.7",
    "multer": "^2.0.2",
    "mysql2": "^3.15.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^20.1.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.2",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "run-script-webpack-plugin": "^0.2.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/rabbitmq(|/.*)$": "<rootDir>/libs/rabbitmq/src/$1",
      "^@app/metrics(|/.*)$": "<rootDir>/libs/metrics/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/outbox(|/.*)$": "<rootDir>/libs/outbox/src/$1",
      "^@app/auth(|/.*)$": "<rootDir>/libs/auth/src/$1"
    }
  }
}
