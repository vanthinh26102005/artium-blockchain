<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #f5f6f8;
      font-family: Arial, sans-serif;
      color: #191414;
    }
    .wrapper {
      padding: 32px 16px 48px;
    }
    .container {
      max-width: 640px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 24px;
      border: 1px solid #ededed;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }
    .header {
      padding: 28px 32px 20px;
      background: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);
      border-bottom: 1px solid #e5e5e5;
    }
    .eyebrow {
      font-size: 11px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #989898;
      margin: 0 0 10px;
    }
    .title {
      font-size: 24px;
      font-weight: 700;
      margin: 0 0 8px;
    }
    .subtitle {
      margin: 0 0 18px;
      color: #595959;
      font-size: 14px;
      line-height: 1.5;
    }
    .cta {
      display: inline-block;
      background: #0066ff;
      color: #ffffff;
      padding: 12px 18px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: bold;
      font-size: 14px;
    }
    .section {
      padding: 24px 32px;
      border-bottom: 1px solid #f0f0f0;
    }
    .section:last-child {
      border-bottom: none;
    }
    .section-title {
      font-size: 11px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #989898;
      margin-bottom: 16px;
    }
    .note {
      background: #f5f5f5;
      padding: 14px 16px;
      border-radius: 16px;
      color: #595959;
      font-size: 13px;
      line-height: 1.5;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    th {
      text-align: left;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #989898;
      padding-bottom: 8px;
    }
    td {
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
      vertical-align: top;
    }
    .totals {
      margin-top: 16px;
      background: #f9fafb;
      border-radius: 16px;
      padding: 16px;
      font-size: 13px;
    }
    .totals-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 8px;
    }
    .totals-row:last-child {
      margin-bottom: 0;
      font-weight: bold;
      font-size: 14px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
    .label {
      font-size: 11px;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #989898;
      margin-bottom: 6px;
    }
    .value {
      font-size: 13px;
      font-weight: bold;
      color: #191414;
    }
    .muted {
      font-size: 12px;
      color: #595959;
      line-height: 1.6;
    }
    .footer {
      text-align: center;
      padding: 24px;
      font-size: 12px;
      color: #989898;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <p class="eyebrow">Quick Sell Invoice</p>
        <h1 class="title">{{#if invoiceNumber}}Invoice {{invoiceNumber}}{{else}}Invoice from Artium{{/if}}</h1>
        <p class="subtitle">
          Review your invoice details and complete payment securely.
          {{#if issueDate}}Issued {{issueDate}}{{/if}}
          {{#if dueDate}} • Due {{dueDate}}{{/if}}
        </p>
        {{#if invoiceUrl}}
        <a class="cta" href="{{invoiceUrl}}">View Invoice</a>
        {{/if}}
      </div>

      {{#if messageHtml}}
      <div class="section">
        <div class="section-title">Message from Seller</div>
        <div class="note">{{{messageHtml}}}</div>
      </div>
      {{/if}}

      <div class="section">
        <div class="section-title">Invoice Summary</div>
        {{#if items}}
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th>Qty</th>
              <th>Price</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {{#each items}}
            <tr>
              <td>{{description}}</td>
              <td>{{quantity}}</td>
              <td>{{unitPriceDisplay}}</td>
              <td>{{lineTotalDisplay}}</td>
            </tr>
            {{#if hasDiscount}}
            <tr>
              <td colspan="4" class="muted">Discount applied: -{{discountDisplay}}</td>
            </tr>
            {{/if}}
            {{/each}}
          </tbody>
        </table>
        {{/if}}

        <div class="totals">
          <div class="totals-row">
            <span>Subtotal</span>
            <span>{{subtotalDisplay}}</span>
          </div>
          <div class="totals-row">
            <span>Discount</span>
            <span>{{discountDisplay}}</span>
          </div>
          <div class="totals-row">
            <span>Tax{{#if taxPercent}} ({{taxPercent}}%){{/if}}</span>
            <span>{{taxDisplay}}</span>
          </div>
          <div class="totals-row">
            <span>Total</span>
            <span>{{totalDisplay}}</span>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Contact Information</div>
        <div class="grid">
          <div>
            <div class="label">Name</div>
            <div class="value">{{#if buyerName}}{{buyerName}}{{else}}-{{/if}}</div>
          </div>
          <div>
            <div class="label">Email</div>
            <div class="value">{{#if buyerEmail}}{{buyerEmail}}{{else}}-{{/if}}</div>
          </div>
          <div>
            <div class="label">Phone</div>
            <div class="value">{{#if buyerPhone}}{{buyerPhone}}{{else}}-{{/if}}</div>
          </div>
          <div>
            <div class="label">Sales Tax ZIP</div>
            <div class="value">{{#if taxZipcode}}{{taxZipcode}}{{else}}-{{/if}}</div>
          </div>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Payment Method</div>
        <p class="muted">
          Pay securely online using card, Google Pay, or Klarna. Wire transfer details are available inside the invoice link.
        </p>
      </div>

      <div class="footer">
        Powered by <strong>Artium</strong>
      </div>
    </div>
  </div>
</body>
</html>
