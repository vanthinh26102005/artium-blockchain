# ============================================
# CRITICAL SECRETS - Must be changed from defaults
# ============================================

# JWT Secret - Use a strong random 64+ character hex string
JWT_SECRET=your-64-char-hex-secret-key-here-change-in-production

# Ethereum Blockchain
ETHEREUM_QUOTE_SIGNING_SECRET=your-32-byte-or-longer-random-secret-for-quote-signing
PLATFORM_PRIVATE_KEY=0xYourPlatformWalletPrivateKeyHere
PLATFORM_ETH_WALLET=0xYourPlatformWalletAddressHere
BLOCKCHAIN_RPC_URL=https://your-sepolia-rpc-endpoint-here
CONTRACT_ADDRESS=0xYourArtAuctionEscrowContractAddressHere
ETHEREUM_CHECKOUT_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
ETHEREUM_QUOTE_TTL_MS=60000

# Stripe Payments
STRIPE_API_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Database Credentials
# ============================================
# These have defaults in docker-compose but should be changed in production
POSTGRES_PASSWORD=your-strong-postgres-password
SHARED_DB_PASSWORD=your-shared-db-password
IDENTITY_DB_PASSWORD=your-identity-db-password
PAYMENTS_DB_PASSWORD=your-payments-db-password
ORDERS_DB_PASSWORD=your-orders-db-password

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_DEFAULT_USER=your-rabbitmq-username
RABBITMQ_DEFAULT_PASS=your-rabbitmq-password
